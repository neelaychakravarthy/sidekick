# Sidekick iMessage bridge — runs on the Mac alongside BlueBubbles.
# Copy to .env.bridge (gitignored) on the laptop. Load it however you run the
# bridge (e.g. `node --env-file=.env.bridge scripts/imessage-bridge.mjs`).

# Sidekick's public base URL (the Vercel deployment).
SIDEKICK_BASE_URL=https://your-app.vercel.app

# Shared secret — MUST match BLUEBUBBLES_WEBHOOK_SECRET set on Vercel.
BLUEBUBBLES_WEBHOOK_SECRET=

# Local BlueBubbles server (on this Mac). Default port is 1234.
BLUEBUBBLES_LOCAL_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# Send method: apple-script (default, no extra setup) or private-api.
BLUEBUBBLES_SEND_METHOD=apple-script

# Poll cadence (ms).
POLL_INTERVAL_MS=2000
