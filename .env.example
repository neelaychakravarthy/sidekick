# Sidekick — environment variables
# Copy to .env.local for local dev (gitignored).
# Phase 1 (Vercel): set these in Vercel project → Settings → Environment Variables.
# Phase 2 (Eazo): set these in Eazo's Environment Variables panel.
# DATABASE_URL is auto-injected by Vercel Postgres (Phase 1) or Eazo (Phase 2) at build time.

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings only — main LLM stays Anthropic) ---
# Used for semantic memory retrieval. Falls back to recency-only ranking
# if missing. Free tier: 200M tokens/month. Get a key at voyageai.com.
VOYAGE_API_KEY=

# --- Telegram (bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=     # generate: openssl rand -hex 32. Set via setWebhook?secret_token=<this>.
TELEGRAM_BOT_USERNAME=        # e.g., SidekickGroupBot — used by analyzer to detect @-mentions. Falls back to bot.api.getMe() if unset.

# --- Inngest (async jobs) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- NextAuth (auth) ---
NEXTAUTH_SECRET=                 # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # update per-environment (Vercel URL for Phase 1; Eazo URL for Phase 2)

# --- Google OAuth (for NextAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Photon Spectrum (iMessage) ---
# Optional. If unset, the iMessage integration is inert (build still passes).
# Get these from app.photon.codes → Project Settings.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
# From the response of POST /projects/{id}/webhooks/ — shown ONCE. Save immediately.
PHOTON_SIGNING_SECRET=
# Your Photon iMessage line number (e.g. +15551234567). Shown in the connect-group UI.
PHOTON_LINE_NUMBER=

# --- BlueBubbles iMessage backend (alternative to Photon) ---
# Run BlueBubbles Server on a Mac (https://github.com/BlueBubblesApp/bluebubbles-server)
# Configure built-in Cloudflare/Ngrok tunnel; note the public URL + password.
# Then add the webhook in BlueBubbles settings: <your-deploy-url>/api/bluebubbles?secret=<BLUEBUBBLES_WEBHOOK_SECRET>
BLUEBUBBLES_SERVER_URL=
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_WEBHOOK_SECRET=

# --- Database (local dev only; Vercel/Eazo auto-inject in their environments) ---
# DATABASE_URL=postgres://user:pass@localhost:5432/sidekick
