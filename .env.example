# Sidekick — environment variables
# Copy to .env.local for local dev (gitignored).
# Production (Vercel, active): set these in Vercel project → Settings →
# Environment Variables. DATABASE_URL points at Neon (set manually). Eazo
# (deferred — platform 502): same vars go in Eazo's Environment Variables panel
# if/when that path is revisited.

# --- Anthropic (LLM) ---
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings only — main LLM stays Anthropic) ---
# Used for semantic memory retrieval. Falls back to recency-only ranking
# if missing. Free tier: 200M tokens/month. Get a key at voyageai.com.
VOYAGE_API_KEY=

# --- Telegram (bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=     # generate: openssl rand -hex 32. Set via setWebhook?secret_token=<this>.
TELEGRAM_BOT_USERNAME=        # e.g., SidekickGroupBot — used by analyzer to detect @-mentions. Falls back to bot.api.getMe() if unset.

# --- Inngest (async jobs) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- NextAuth (auth) ---
NEXTAUTH_SECRET=                 # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # update per-environment (Vercel URL for Phase 1; Eazo URL for Phase 2)

# --- Google OAuth (for NextAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- iMessage via BlueBubbles (poll-based) ---
# The Vercel app holds NO BlueBubbles credentials — it only enqueues outbound
# iMessages and authenticates the laptop bridge with a shared secret. The
# BlueBubbles server URL/password live on the laptop bridge (see .env.bridge.example).
BLUEBUBBLES_WEBHOOK_SECRET=   # shared secret: receive webhook auth + outbox poll auth. openssl rand -hex 32
BLUEBUBBLES_BOT_HANDLE=       # the Sidekick Apple ID handle (email), shown in the connect-page instructions

# --- Photon Spectrum (iMessage — DORMANT, alternative backend) ---
# Optional. If unset, the iMessage integration is inert (build still passes).
# Get these from app.photon.codes → Project Settings.
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
# From the response of POST /projects/{id}/webhooks/ — shown ONCE. Save immediately.
PHOTON_SIGNING_SECRET=
# Your Photon iMessage line number (e.g. +15551234567). Shown in the connect-group UI.
PHOTON_LINE_NUMBER=

# --- Encryption (for BYO Anthropic key storage) ---
# Generate: openssl rand -hex 32
# 32+ chars required. Used as the AES-256-GCM key (SHA-256 derived).
ENCRYPTION_SECRET=

# --- Rate limiting (free-tier users on the team's Anthropic key) ---
# Per-user daily cap on LLM calls. Users with their own key (saved in
# the dashboard) bypass this entirely. Resets at UTC midnight.
DAILY_LLM_CALL_LIMIT=50

# --- Database ---
# Local dev: point at your local Postgres.
# Production (Vercel): set DATABASE_URL to your Neon POOLED connection string
# (host contains "-pooler"). Optionally set DIRECT_DATABASE_URL to Neon's
# DIRECT (unpooled) string — drizzle-kit migrations use it if present, which
# avoids DDL-over-pgBouncer issues. App runtime always uses DATABASE_URL.
DATABASE_URL=
DIRECT_DATABASE_URL=
